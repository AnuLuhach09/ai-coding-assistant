PORT=5000
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_assistant?schema=public"
JWT_SECRET="your-jwt-access-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-secret"

# Comma-separated list of allowed frontend origins for CORS, e.g.
# "https://my-frontend.up.railway.app,http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"

# Set to "true" only when the frontend and backend are on different domains
# (e.g. two separate Railway services). Leave unset for same-site/local dev.
CROSS_SITE_COOKIES="false"

# OPTIONAL — leave blank to disable. If unset, the app boots and runs
# normally without caching (Redis) or RAG/embeddings search (Chroma).
REDIS_URL=""
CHROMA_URL=""

# AI Provider API Keys
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
GROQ_API_KEY=""
OPENROUTER_API_KEY=""
OLLAMA_API_URL="http://localhost:11434"
